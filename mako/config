# ~/.config/mako/config
# Tema Cybersigilism / Cyber-Gothic

# Configuración Global
font=FiraCode Nerd Font 11
background-color=#11111b
text-color=#cdd6f4
border-color=#cba6f7
border-size=2
border-radius=4
margin=20
padding=12
width=320
height=100
default-timeout=5000
max-visible=5
sort=-time
layer=overlay

# Personalización por urgencia
[urgency=low]
border-color=#313244

[urgency=high]
border-color=#f5c2e7
default-timeout=0
